local petWebhookURL   = _G.PET_WEBHOOK or ""
local discordUserID   = _G.DISCORD_ID or ""

local DEBUG_HUB = true
local useProxy = true

local function getProxiedURL(url)
    if not useProxy then return url end
    return url:gsub("https://discord.com/", "https://webhook.lewisakura.moe/")
end

local HttpService = game:GetService("HttpService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local lp = Players.LocalPlayer

local function debugLog(msg)
    if DEBUG_HUB then
        print("🛠️ [DEBUG]: " .. tostring(msg))
    end
end

local function formatNumber(v)
    if not v then return "0" end
    local s = tostring(v)
    local parts = string.split(s, ".")
    local intPart = parts[1]:reverse():gsub("%d%d%d", "%1."):reverse():gsub("^%.", "")
    if parts[2] then
        return intPart .. "," .. parts[2]
    end
    return intPart
end

-- [[ PET NADİRİK KONTROL SİSTEMİ ]] --
local FinalTargets = {
    ["Legendary"] = false,
    ["Mythical"] = false,
    ["Secret I"] = true,
    ["Secret II"] = true,
    ["Secret III"] = true,
    ["Secret X"] = true
}

local PetData = {}
local function LoadPetStats()
    pcall(function() 
        PetData = require(ReplicatedStorage:WaitForChild("Game"):WaitForChild("PetStats"):WaitForChild("Pets")) 
    end)
end
task.spawn(LoadPetStats)

local request_func = (request or syn and syn.request or http and http.request)

local function getInventoryPetCount(targetPetName)
    if not targetPetName then return 0 end
    local count = 0
    local targetLower = tostring(targetPetName):lower()
    
    local targetIDs = {}
    pcall(function()
        for id, data in pairs(PetData) do
            if (data.Name and data.Name:lower():find(targetLower)) or tostring(id):lower() == targetLower then
                targetIDs[tostring(id):lower()] = true
                if data.Name then targetIDs[data.Name:lower()] = true end
            end
        end
    end)
    targetIDs[targetLower] = true

    pcall(function()
        local searchPaths = {lp, ReplicatedStorage:FindFirstChild("PlayerData"), workspace:FindFirstChild("PlayerPets")}
        for _, area in pairs(searchPaths) do
            if area then
                local currentArea = area:FindFirstChild(lp.Name) or area:FindFirstChild(tostring(lp.UserId)) or (area == lp and lp)
                if currentArea then
                    for _, obj in pairs(currentArea:GetDescendants()) do
                        local isMatch = false
                        local oName = obj.Name:lower()
                        for tID, _ in pairs(targetIDs) do if oName:find(tID) then isMatch = true break end end
                        if isMatch then count = count + 1 end
                    end
                end
            end
        end
    end)
    return count
end

-- [[ DUPLICATE PREVENTION LOGIC ]] --
local RecentNotifications = {} 

local function isDuplicate(petName, rarity)
    local key = string.format("%s_%s", tostring(petName), tostring(rarity))
    local now = tick()
    for k, t in pairs(RecentNotifications) do if now - t > 5 then RecentNotifications[k] = nil end end
    if RecentNotifications[key] and now - RecentNotifications[key] < 3 then return true end
    RecentNotifications[key] = now
    return false
end

local function sendPetNotification(petName, rarity, petType, multiplier, eggName, imageId)
    if isDuplicate(petName, rarity) then return end
    task.wait(2) 

    local totalEggs = 0
    pcall(function()
        local folder = lp:FindFirstChild("leaderstats") or lp:FindFirstChild("PlayerStats")
        if folder then
            local eggObj = folder:FindFirstChild("Eggs") or folder:FindFirstChild("TotalEggs")
            if eggObj then totalEggs = eggObj.Value end
        end
    end)

    local invCount = getInventoryPetCount(petName)
    local thumbnailUrl = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. lp.UserId .. "&width=420&height=420&format=png"
    local cleanImageId = tostring(imageId or ""):gsub("%D", "")
    if cleanImageId ~= "" and cleanImageId ~= "0" then
        thumbnailUrl = string.format("https://www.roblox.com/asset-thumbnail/image?assetId=%s&width=420&height=420&format=png", cleanImageId)
    end

    local data = {
        ["content"] = discordUserID ~= "" and "<@" .. discordUserID .. ">" or "",
        ["embeds"] = {{
            ["title"] = string.format("🐶 %s (%s) | Sadece Senin Hesabın", petName, petType or "Normal"),
            ["description"] = string.format("**__Hesap__:** %s\n**Pet:** %s\n**Nadirik:** %s\n\n**Çarpan:** x%s\n**Yumurta:** %s\n\n📊 **İstatistik:**\n**Toplam Açılan:** %s 🥚\n**Envanterinde:** %sx", 
            lp.Name, petName, rarity, formatNumber(multiplier or "0"), tostring(eggName or "Bilinmiyor"), formatNumber(totalEggs), formatNumber(invCount)),
            ["thumbnail"] = {["url"] = thumbnailUrl},
            ["color"] = 10066329,
            ["timestamp"] = DateTime.now():ToIsoDate(),
            ["footer"] = { ["text"] = "Gelişmiş Filtreleme Sistemi" }
        }}
    }

    pcall(function()
        request_func({
            Url = getProxiedURL(petWebhookURL),
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
end

local function GetNetwork()
    for _, v in pairs(ReplicatedStorage:GetChildren()) do
        if v:IsA("Folder") and (v:FindFirstChild("Events") or v.Name:find("-")) then return v end
    end
    return nil
end

local ConnectedRemotes = {}

local function ConnectRemote(remote)
    if not remote:IsA("RemoteEvent") or ConnectedRemotes[remote] then return end
    
    local rName = remote.Name:lower()
    
    -- [[ AGRESİF FİLTRELEME ]] --
    -- Kuşanma (Equip), En İyi Pet (Best), Trade ve diğer gereksiz işlemleri engelle
    local excluded = {"equip", "best", "trade", "unequip", "wear", "select", "use", "delete", "trace", "save", "load"}
    for _, word in pairs(excluded) do
        if rName:find(word) then return end
    end

    -- Sadece Yumurta Açma (Hatch/Open) işlemlerine odaklan
    if not (rName:find("hatch") or rName:find("open")) then return end

    ConnectedRemotes[remote] = remote.OnClientEvent:Connect(function(...)
        local args = {...}
        
        -- ÖNEMLİ: Gelen verinin bu hesaba (LocalPlayer) ait olup olmadığını kontrol et
        local isActuallyMe = false
        for _, arg in pairs(args) do
            if arg == lp or (type(arg) == "table" and (arg.Player == lp or arg.Owner == lp or arg.UserId == lp.UserId or arg.OwnerId == lp.UserId)) then
                isActuallyMe = true
                break
            end
        end

        for _, arg in pairs(args) do
            if type(arg) == "table" then
                local name = arg.PetName or arg.Name or arg.id
                if name then
                    -- Sahiplik Kontrolünü Doğrula (Tablo içindeki ID'ye veya argümanlardaki oyuncuya göre)
                    local argOwnerId = arg.OwnerId or arg.UserId
                    local finalIsMe = isActuallyMe or (argOwnerId == lp.UserId)

                    -- Eğer veri kesinlikle başka bir ID'ye aitse veya bize ait olduğu kanıtlanamadıysa atla
                    if argOwnerId and argOwnerId ~= lp.UserId then continue end
                    if not finalIsMe then continue end

                    local nameStr = tostring(name)
                    local baseData = PetData[nameStr]
                    local actualRarity = baseData and (baseData.Rarity or baseData.Tier) or "Unknown"
                    
                    if FinalTargets[actualRarity] then
                        task.spawn(function()
                            sendPetNotification(nameStr, actualRarity, arg.Tier or "Normal", baseData and baseData.Multiplier, "Hatched Egg", baseData and baseData.Image)
                        end)
                    end
                end
            end
        end
    end)
end

local function SetupListeners()
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") then
            local lowName = obj.Name:lower()
            if lowName:find("hatch") or lowName:find("open") then
                ConnectRemote(obj)
            end
        end
    end
    local net = GetNetwork()
    if net then
        local events = net:FindFirstChild("Events")
        if events then
            for _, r in pairs(events:GetChildren()) do ConnectRemote(r) end
            events.ChildAdded:Connect(ConnectRemote)
        end
    end
end

if not game:IsLoaded() then game.Loaded:Wait() end
task.spawn(SetupListeners)
debugLog("Sadece yerel hesap için aktif!")
