local function formatNumber(v)
    if not v then return "0" end
    local s = tostring(v)
    local parts = string.split(s, ".")
    local intPart = parts[1]:reverse():gsub("%d%d%d", "%1."):reverse():gsub("^%.", "")
    if parts[2] then
        return intPart .. "," .. parts[2]
    end
    return intPart
end

-- [[ PET NADİRİK KONTROL SİSTEMİ ]] --
-- [[ GENİŞLETİLMİŞ NADİRİK LİSTESİ ]] --
local FinalTargets = {
    ["Legendary"] = true,
    ["Mythical"] = true,
    ["Secret I"] = true,
    ["Secret II"] = true,
    ["Secret III"] = true, 
    ["Secret X"] = true
}

local function isMe(val)
    if not val then return false end
    return val == lp or tostring(val) == tostring(lp.UserId) or tostring(val) == lp.Name
end

local function ConnectRemote(remote)
    if not remote:IsA("RemoteEvent") or ConnectedRemotes[remote] then return end
    
    local rName = remote.Name:lower()
    
    -- [[ KRİTİK FİLTRE: Sadece gerçekten gereksizleri engelle ]] --
    local blockedWords = {"equipbest", "best", "trade", "unequip", "wear", "select", "use", "delete", "trace", "save", "load", "friend"}
    for _, word in pairs(blockedWords) do
        if rName:find(word) then return end
    end

    ConnectedRemotes[remote] = remote.OnClientEvent:Connect(function(...)
        local args = {...}
        
        local isActuallyMe = false
        local foundOtherPlayer = false
        
        -- 1. ADIM: Sahiplik ve Diğer Oyuncu Kontrolü
        for _, arg in pairs(args) do
            if isMe(arg) then
                isActuallyMe = true
            elseif typeof(arg) == "Instance" and arg:IsA("Player") and arg ~= lp then
                foundOtherPlayer = true
            end
            
            if type(arg) == "table" then
                for k, v in pairs(arg) do
                    if isMe(v) or isMe(k) then isActuallyMe = true end
                    -- Eğer tabloda başka birinin UserID'si veya ismi net varsa, bu bizim değildir
                    if (k == "OwnerId" or k == "UserId" or k == "player_id") and tostring(v) ~= tostring(lp.UserId) then
                        foundOtherPlayer = true
                    end
                end
            end
        end

        -- Eğer kesinlikle başka bir oyuncuya aitse (foundOtherPlayer true) ve bizim olduğumuza dair kanıt yoksa atla
        if foundOtherPlayer and not isActuallyMe then return end

        -- 2. ADIM: Pet Verisi Arama
        for _, arg in pairs(args) do
            if type(arg) == "table" then
                -- Olası pet isim anahtarları
                local rawName = arg.PetName or arg.Name or arg.id or arg.pet_id or arg.Pet
                local rawRarity = arg.Rarity or arg.Tier or arg.rarity or arg.tier
                
                if rawName then
                    local nameStr = tostring(rawName)
                    local baseData = PetData[nameStr] or {}
                    local rarity = tostring(rawRarity or baseData.Rarity or baseData.Tier or "Unknown")
                    
                    -- Nadirlik eşleşmesi (Kısmi kontrol: "Secret" içermesi yeterli)
                    local isTarget = false
                    for target, _ in pairs(FinalTargets) do
                        if rarity:find(target) or nameStr:find(target) then
                            isTarget = true
                            break
                        end
                    end
                    
                    if isTarget then
                        debugLog("✅ BİLDİRİM: " .. nameStr .. " [" .. rarity .. "]")
                        task.spawn(function()
                            sendPetNotification(nameStr, rarity, arg.Tier or "Normal", baseData.Multiplier, "Hatched/Obtained", baseData.Image)
                        end)
                    end
                end
            end
        end
    end)
end

local function SetupListeners()
    -- ReplicatedStorage altındaki HER ŞEYİ tara
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") then
            ConnectRemote(obj)
        end
    end
    
    -- Dinamik olarak eklenenleri yakala
    ReplicatedStorage.DescendantAdded:Connect(function(obj)
        if obj:IsA("RemoteEvent") then ConnectRemote(obj) end
    end)

    local net = GetNetwork()
    if net then
        local events = net:FindFirstChild("Events")
        if events then
            for _, r in pairs(events:GetChildren()) do ConnectRemote(r) end
            events.ChildAdded:Connect(ConnectRemote)
        end
    end
end

if not game:IsLoaded() then game.Loaded:Wait() end
