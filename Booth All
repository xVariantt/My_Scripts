-- SADECE BİRİ SATIN ALDIĞINDA ÇALIŞACAK WEBHOOK:
local function SendWebhookSaleNotification(buyerName)
    if tick() - lastSaleTime < 3 then return end 
    lastSaleTime = tick()
    
    if not SETTINGS.EnableWebhook or not SETTINGS.DiscordWebhookUrl or SETTINGS.DiscordWebhookUrl == "" then return end
    
    local thumbnailUrl = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. LocalPlayer.UserId .. "&width=420&height=420&format=png"
    
    local pingContent = ""
    if SETTINGS.PingDiscordUser and SETTINGS.PingDiscordUser ~= "" then
        pingContent = "<@" .. SETTINGS.PingDiscordUser .. ">"
    end
    
    local data = {
        ["content"] = pingContent,
        ["embeds"] = {{
            ["title"] = "🛒 Pet Satıldı! (" .. LocalPlayer.Name .. ")",
            ["description"] = string.format("Tebrikler! Standından bir pet başarıyla satın alındı.\n\n🛍️ **Alıcı:** `%s`", tostring(buyerName)),
            ["thumbnail"] = {["url"] = thumbnailUrl},
            ["color"] = 65280, -- Güzel, parlak bir yeşil renk (Başarılı İşlem)
            ["timestamp"] = DateTime.now():ToIsoDate(),
            ["footer"] = { ["text"] = "Tap Simulator Auto Booth" }
        }}
    }
    
    local finalUrl = SETTINGS.DiscordWebhookUrl:gsub("https://discord.com/", "https://webhook.lewisakura.moe/")
    
    task.spawn(function()
        pcall(function()
            local request_func = (request or syn and syn.request or http and http.request)
            if request_func then
                request_func({
                    Url = finalUrl,
                    Method = "POST",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = HttpService:JSONEncode(data)
                })
            end
        end)
    end)
end

-- EKRANDAKİ YAZILARI DİNLEYEN SİSTEM:
local function SetupSaleTracker()
    local function checkText(desc)
        if not desc or not desc.Parent then return end
        pcall(function()
            local text = tostring(desc.Text)
            
            text = string.gsub(text, "<[^>]+>", "")
            
            local txtLower = string.lower(text)
            if string.match(txtLower, "bought your item") then
                local buyer = string.match(text, "%S+") or "Bilinmeyen_Oyuncu"
                SendWebhookSaleNotification(buyer)
            end
        end)
    end

    local PlayerGui = LocalPlayer:WaitForChild("PlayerGui", 10)
    if PlayerGui then
        for _, desc in ipairs(PlayerGui:GetDescendants()) do
            if desc:IsA("TextLabel") or desc:IsA("TextBox") then
                checkText(desc)
                desc:GetPropertyChangedSignal("Text"):Connect(function() checkText(desc) end)
            end
        end
        PlayerGui.DescendantAdded:Connect(function(desc)
            if desc:IsA("TextLabel") or desc:IsA("TextBox") then
                task.delay(0.1, function() checkText(desc) end)
                desc:GetPropertyChangedSignal("Text"):Connect(function() checkText(desc) end)
            end
        end)
    end
end
