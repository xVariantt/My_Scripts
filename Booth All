local function ServerHop(targetPlaceIdOverride)
    if not SETTINGS.HopIfNoBooth then return false end
    
    local placeId = targetPlaceIdOverride or game.PlaceId
    print("[SİSTEM] Garanti girilebilecek kalabalık bir sunucu aranıyor... (PlaceID: " .. tostring(placeId) .. ")")
    
    local bestServer = nil
    local highestPlayers = 0
    
    local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true"
    
    for i = 1, 5 do 
        local success, result = pcall(function() return game:HttpGet(url) end)
        if not success or not result then break end
        
        local successDec, data = pcall(function() return HttpService:JSONDecode(result) end)
        if not successDec or not data or not data.data then break end
        
        for _, server in ipairs(data.data) do
            if type(server) == "table" and type(server.playing) == "number" and type(server.maxPlayers) == "number" then
                if server.playing < (server.maxPlayers - 2) and server.id ~= game.JobId then
                    if server.playing > highestPlayers then
                        highestPlayers = server.playing
                        bestServer = server.id
                    end
                end
            end
        end
        
        if bestServer then 
            break 
        end
        
        if data.nextPageCursor then
            url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true&cursor=" .. data.nextPageCursor
        else
            break
        end
    end
    
    if bestServer then
        print("[SİSTEM] Uygun kalabalıkta (" .. tostring(highestPlayers) .. " kişi) server bulundu! Uçuluyor...")
        pcall(function()
            TeleportService:TeleportToPlaceInstance(placeId, bestServer, LocalPlayer)
        end)
        return true
    end
    
    warn("[HATA] Uygun bir server bulunamadı. Biraz bekledikten sonra baştan denenecek.")
    return false
end

